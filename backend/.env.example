# Copy to `.env` and adjust for your environment.

# SQLAlchemy database URL. Production uses PostgreSQL (psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/diagram_copilot

# Comma/JSON list of allowed CORS origins (the Vite dev + preview servers).
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Seed a few example projects on first startup when the database is empty.
SEED_ON_STARTUP=true

# Environment name: development | production
ENVIRONMENT=development
